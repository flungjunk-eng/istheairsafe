---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import AqiDial from '../../components/AqiDial.jsx';
import cities from '../../data/cities.json';
import { fetchCityData, getAqiLevel, getWeatherDescription } from '../../utils/waqi.js';

// Match route: /air-quality/[countrySlug]/[citySlug]
const { slug } = Astro.params;
const parts = (slug || '').split('/').filter(Boolean);

// Find city by countrySlug + slug OR just slug
let city = null;
if (parts.length === 2) {
  const [countrySlug, citySlug] = parts;
  city = cities.find(c => c.countrySlug === countrySlug && c.slug === citySlug);
}
if (!city && parts.length === 1) {
  city = cities.find(c => c.slug === parts[0]);
}

if (!city) {
  return Astro.redirect('/404');
}

const token = (Astro.locals?.runtime?.env?.WAQI_TOKEN) || import.meta.env.WAQI_TOKEN || 'demo';
const { aqi: aqiData, weather } = await fetchCityData(city.waqiId, token);

const aqi = aqiData?.aqi ?? null;
const level = getAqiLevel(aqi);
const pollutants = aqiData?.pollutants || {};
const forecast = aqiData?.forecast || {};

const cityLabel = city.state ? `${city.name}, ${city.state}` : `${city.name}, ${city.country}`;
const pageTitle = `${city.name} Air Quality — Is the Air Safe? | Real-Time AQI`;
const pageDesc = level
  ? `Live air quality index for ${cityLabel}: AQI ${aqi} — ${level.label}. Check PM2.5, PM10, ozone levels and health advice for ${city.name}.`
  : `Live air quality data for ${cityLabel}. Real-time AQI, PM2.5, health guidance and 7-day forecast.`;

const updatedAt = aqiData?.time
  ? new Date(aqiData.time).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' })
  : null;

// JSON-LD
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageTitle,
  description: pageDesc,
  url: `https://istheairsafe.com${city.url}`,
  dateModified: new Date().toISOString(),
  about: {
    '@type': 'Place',
    name: city.name,
    addressCountry: city.country,
  },
};

const pollutantDefs = [
  { key: 'pm25', label: 'PM2.5', unit: 'µg/m³', desc: 'Fine particulate matter' },
  { key: 'pm10', label: 'PM10',  unit: 'µg/m³', desc: 'Coarse particulate matter' },
  { key: 'o3',   label: 'Ozone', unit: 'ppb',    desc: 'Ground-level ozone' },
  { key: 'no2',  label: 'NO₂',   unit: 'ppb',    desc: 'Nitrogen dioxide' },
  { key: 'so2',  label: 'SO₂',   unit: 'ppb',    desc: 'Sulfur dioxide' },
  { key: 'co',   label: 'CO',    unit: 'ppm',    desc: 'Carbon monoxide' },
];

const weatherDesc = weather?.weatherCode != null ? getWeatherDescription(weather.weatherCode) : null;
---

<Base title={pageTitle} description={pageDesc} canonical={city.url} jsonLd={jsonLd}>
  <div class="container" style="padding-top: 2.5rem; padding-bottom: 4rem;">

    <!-- Breadcrumb -->
    <nav style="font-size: 0.8rem; color: var(--text-subtle); margin-bottom: 1.5rem; font-family: var(--font-mono);">
      <a href="/" style="color: var(--text-muted);">Home</a>
      <span style="margin: 0 0.4rem;">›</span>
      <a href="/rankings" style="color: var(--text-muted);">Rankings</a>
      <span style="margin: 0 0.4rem;">›</span>
      <span>{city.name}</span>
    </nav>

    <!-- Hero -->
    <div style="display: grid; grid-template-columns: 1fr auto; gap: 2rem; align-items: start; margin-bottom: 2rem;">
      <div>
        <h1 style="font-size: clamp(2rem, 5vw, 3.25rem); letter-spacing: -0.03em; margin-bottom: 0.25rem;">
          {city.name}
          {level && (
            <span style={`color: ${level.color}; display: block; font-size: 0.65em;`}>
              {level.label}
            </span>
          )}
        </h1>
        <p style="color: var(--text-muted); font-size: 1rem; margin-bottom: 0.75rem;">
          {cityLabel} · {city.country}
        </p>
        {updatedAt && (
          <p style="font-size: 0.75rem; color: var(--text-subtle); font-family: var(--font-mono);">
            Updated: {updatedAt}
          </p>
        )}
      </div>
    </div>

    <!-- Main Grid -->
    <div style="display: grid; grid-template-columns: 340px 1fr; gap: 1.5rem; align-items: start;">

      <!-- Left: Dial + Quick Stats -->
      <div>
        <!-- AQI Dial Card -->
        <div class="card" style="padding: 2rem 1.5rem; text-align: center; margin-bottom: 1.5rem;">
          <AqiDial aqi={aqi} client:load />
          {level && (
            <div style={`margin-top: 1.25rem; padding: 1rem; background: ${level.bg}; border-radius: 8px; border: 1px solid ${level.color}30;`}>
              <p style={`font-size: 0.875rem; color: ${level.text}; line-height: 1.5;`}>
                {level.advice}
              </p>
            </div>
          )}
        </div>

        <!-- Weather Card -->
        {weather && (
          <div class="card" style="padding: 1.25rem;">
            <h3 style="font-family: var(--font-sans); font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 1rem;">
              Current Weather
            </h3>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
              {weather.temperature != null && (
                <div>
                  <div style="font-size: 1.5rem; font-family: var(--font-serif);">{weather.temperature}°C</div>
                  <div style="font-size: 0.75rem; color: var(--text-muted);">Temperature</div>
                </div>
              )}
              {weather.humidity != null && (
                <div>
                  <div style="font-size: 1.5rem; font-family: var(--font-serif);">{weather.humidity}%</div>
                  <div style="font-size: 0.75rem; color: var(--text-muted);">Humidity</div>
                </div>
              )}
              {weather.windSpeed != null && (
                <div>
                  <div style="font-size: 1.5rem; font-family: var(--font-serif);">{weather.windSpeed}</div>
                  <div style="font-size: 0.75rem; color: var(--text-muted);">mph wind</div>
                </div>
              )}
              {weatherDesc && (
                <div>
                  <div style="font-size: 0.875rem; font-weight: 500;">{weatherDesc}</div>
                  <div style="font-size: 0.75rem; color: var(--text-muted);">Conditions</div>
                </div>
              )}
            </div>
          </div>
        )}
      </div>

      <!-- Right: Pollutants + Forecast + SEO -->
      <div>
        <!-- Pollutants -->
        <div class="card" style="padding: 1.5rem; margin-bottom: 1.5rem;">
          <h2 style="font-family: var(--font-sans); font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 1.25rem;">
            Pollutant Breakdown
          </h2>
          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem;">
            {pollutantDefs.map(p => {
              const val = pollutants[p.key];
              return (
                <div style="padding: 1rem; background: var(--bg); border-radius: 8px; border: 1px solid var(--border-light);">
                  <div style="font-family: var(--font-mono); font-size: 1.25rem; font-weight: 500; color: var(--text);">
                    {val != null ? val : '—'}
                  </div>
                  <div style="font-weight: 600; font-size: 0.875rem; margin-top: 0.2rem;">{p.label}</div>
                  <div style="font-size: 0.7rem; color: var(--text-muted);">{p.unit} · {p.desc}</div>
                </div>
              );
            })}
          </div>
          {aqiData?.dominentPollutant && (
            <p style="font-size: 0.8rem; color: var(--text-muted); margin-top: 1rem; font-family: var(--font-mono);">
              Dominant pollutant: <strong>{aqiData.dominentPollutant.toUpperCase()}</strong>
            </p>
          )}
          {Object.values(pollutants).every(v => v === null) && aqi != null && (
            <p style="font-size: 0.8rem; color: var(--text-subtle); margin-top: 1rem; font-style: italic;">
              This monitoring station reports an overall AQI but does not publish individual pollutant readings.
            </p>
          )}
        </div>

        <!-- AQI Forecast (if available) -->
        {forecast?.pm25?.length > 0 && (
          <div class="card" style="padding: 1.5rem; margin-bottom: 1.5rem;">
            <h2 style="font-family: var(--font-sans); font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 1.25rem;">
              PM2.5 Forecast (next 7 days)
            </h2>
            <div style="display: flex; gap: 0.75rem; overflow-x: auto; padding-bottom: 0.5rem;">
              {forecast.pm25.slice(0, 7).map((day) => {
                const avgAqi = Math.round((day.avg + day.max) / 2);
                const lvl = getAqiLevel(avgAqi);
                return (
                  <div style={`flex-shrink: 0; text-align: center; padding: 0.75rem; background: ${lvl?.bg || 'var(--bg)'}; border-radius: 8px; border: 1px solid ${lvl?.color || 'var(--border)'}30; min-width: 70px;`}>
                    <div style="font-size: 0.7rem; color: var(--text-muted); font-family: var(--font-mono); margin-bottom: 0.4rem;">
                      {new Date(day.day).toLocaleDateString('en-US', { weekday: 'short', month: 'numeric', day: 'numeric' })}
                    </div>
                    <div style={`font-family: var(--font-serif); font-size: 1.1rem; color: ${lvl?.color || 'var(--text)'};`}>
                      {day.avg}
                    </div>
                    <div style="font-size: 0.65rem; color: var(--text-subtle);">avg AQI</div>
                  </div>
                );
              })}
            </div>
          </div>
        )}

        <!-- Health Guidance -->
        {level && (
          <div class="card" style="padding: 1.5rem; margin-bottom: 1.5rem;">
            <h2 style="font-family: var(--font-sans); font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 1rem;">
              Health Guidance
            </h2>
            <div style="display: flex; flex-direction: column; gap: 0.75rem;">
              {level.min <= 50 && (
                <>
                  <div style="display: flex; gap: 0.75rem; align-items: flex-start;">
                    <span>✅</span>
                    <div><strong>General population:</strong> No restrictions. Enjoy outdoor activities.</div>
                  </div>
                  <div style="display: flex; gap: 0.75rem; align-items: flex-start;">
                    <span>✅</span>
                    <div><strong>Sensitive groups:</strong> Air quality is good. Normal activities are fine.</div>
                  </div>
                </>
              )}
              {level.min > 50 && level.min <= 100 && (
                <>
                  <div style="display: flex; gap: 0.75rem; align-items: flex-start;">
                    <span>⚠️</span>
                    <div><strong>Unusually sensitive people:</strong> Consider reducing prolonged outdoor exertion.</div>
                  </div>
                  <div style="display: flex; gap: 0.75rem; align-items: flex-start;">
                    <span>✅</span>
                    <div><strong>General population:</strong> No restrictions for most people.</div>
                  </div>
                </>
              )}
              {level.min > 100 && level.min <= 150 && (
                <>
                  <div style="display: flex; gap: 0.75rem; align-items: flex-start;">
                    <span>⚠️</span>
                    <div><strong>Sensitive groups (asthma, heart disease, elderly, children):</strong> Reduce prolonged or heavy outdoor exertion.</div>
                  </div>
                  <div style="display: flex; gap: 0.75rem; align-items: flex-start;">
                    <span>✅</span>
                    <div><strong>General population:</strong> Unusually sensitive individuals should watch for symptoms.</div>
                  </div>
                </>
              )}
              {level.min > 150 && level.min <= 200 && (
                <>
                  <div style="display: flex; gap: 0.75rem; align-items: flex-start;">
                    <span>🚫</span>
                    <div><strong>Sensitive groups:</strong> Avoid prolonged outdoor exertion. Move activities indoors.</div>
                  </div>
                  <div style="display: flex; gap: 0.75rem; align-items: flex-start;">
                    <span>⚠️</span>
                    <div><strong>General population:</strong> Reduce prolonged or heavy outdoor exertion. Take more breaks.</div>
                  </div>
                </>
              )}
              {level.min > 200 && level.min <= 300 && (
                <>
                  <div style="display: flex; gap: 0.75rem; align-items: flex-start;">
                    <span>🚫</span>
                    <div><strong>Sensitive groups:</strong> Avoid all outdoor physical activity.</div>
                  </div>
                  <div style="display: flex; gap: 0.75rem; align-items: flex-start;">
                    <span>⚠️</span>
                    <div><strong>General population:</strong> Avoid prolonged outdoor exertion. Consider wearing N95 mask outdoors.</div>
                  </div>
                </>
              )}
              {level.min > 300 && (
                <>
                  <div style="display: flex; gap: 0.75rem; align-items: flex-start;">
                    <span>🚨</span>
                    <div><strong>Everyone:</strong> Avoid all outdoor activity. Stay indoors with air purification.</div>
                  </div>
                  <div style="display: flex; gap: 0.75rem; align-items: flex-start;">
                    <span>🚨</span>
                    <div><strong>Sensitive groups:</strong> Remain indoors. Seek medical attention if experiencing symptoms.</div>
                  </div>
                </>
              )}
              <div style="display: flex; gap: 0.75rem; align-items: flex-start;">
                <span>💨</span>
                <div>Keep windows closed if air quality is Unhealthy or above. Use air purifiers with HEPA filters indoors.</div>
              </div>
            </div>
          </div>
        )}

        <!-- Data attribution -->
        {aqiData?.attributions?.length > 0 && (
          <p style="font-size: 0.75rem; color: var(--text-subtle); font-family: var(--font-mono);">
            Data from: {aqiData.attributions.map(a => a.name).join(', ')}
          </p>
        )}
      </div>
    </div>

    <!-- SEO Text Block -->
    <div class="card" style="padding: 2rem; margin-top: 2rem;">
      <h2 style="font-size: 1.5rem; margin-bottom: 1rem;">
        Is the air safe in {city.name} today?
      </h2>
      <div style="color: var(--text-muted); line-height: 1.8; font-size: 0.95rem;">
        <p style="margin-bottom: 1rem;">
          {aqi != null
            ? `The current Air Quality Index (AQI) in ${city.name} is ${aqi}, which is classified as "${level?.label}". ${level?.advice}`
            : `Real-time air quality data for ${city.name} is currently unavailable. Please check back shortly.`
          }
        </p>
        <p style="margin-bottom: 1rem;">
          The AQI scale runs from 0 to 500, where lower values indicate cleaner air. 
          Values between 0–50 are considered <strong>Good</strong>, 51–100 are <strong>Moderate</strong>, 
          101–150 are <strong>Unhealthy for Sensitive Groups</strong>, 151–200 are <strong>Unhealthy</strong>, 
          201–300 are <strong>Very Unhealthy</strong>, and 301–500 are <strong>Hazardous</strong>.
        </p>
        <p>
          Air quality in {city.name}{city.state ? `, ${city.state}` : ''} is monitored by local environmental agencies 
          and reported through the World Air Quality Index project. The data shown here is updated in real-time 
          and includes PM2.5, PM10, ozone, nitrogen dioxide, sulfur dioxide, and carbon monoxide measurements.
        </p>
      </div>
    </div>

    <!-- AQI Scale Reference -->
    <div style="margin-top: 2rem;">
      <h3 style="font-size: 1.1rem; margin-bottom: 1rem;">AQI Scale Reference</h3>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 0.75rem;">
        {[
          { range: '0–50',   label: 'Good',                        color: '#4ade80', bg: '#f0fdf4', text: '#166534' },
          { range: '51–100', label: 'Moderate',                    color: '#facc15', bg: '#fefce8', text: '#854d0e' },
          { range: '101–150',label: 'Unhealthy for Sensitive Groups', color: '#fb923c', bg: '#fff7ed', text: '#9a3412' },
          { range: '151–200',label: 'Unhealthy',                   color: '#f87171', bg: '#fef2f2', text: '#991b1b' },
          { range: '201–300',label: 'Very Unhealthy',              color: '#c084fc', bg: '#faf5ff', text: '#6b21a8' },
          { range: '301+',   label: 'Hazardous',                   color: '#f43f5e', bg: '#fff1f2', text: '#881337' },
        ].map(band => (
          <div style={`padding: 0.75rem 1rem; background: ${band.bg}; border-radius: 8px; border: 1px solid ${band.color}40;`}>
            <div style={`font-family: var(--font-mono); font-size: 0.8rem; color: ${band.color}; font-weight: 600;`}>{band.range}</div>
            <div style={`font-size: 0.85rem; font-weight: 600; color: ${band.text}; margin-top: 0.2rem;`}>{band.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <style>
    @media (max-width: 768px) {
      .main-grid {
        grid-template-columns: 1fr !important;
      }
      .pollutants-grid {
        grid-template-columns: repeat(2, 1fr) !important;
      }
    }
  </style>
</Base>
