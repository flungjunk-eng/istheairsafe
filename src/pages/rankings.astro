---
export const prerender = true;

import Base from '../layouts/Base.astro';
import cities from '../data/cities.json';

const rankingCityIds = [
  'beijing', 'delhi', 'lahore', 'mumbai', 'dhaka', 'kolkata',
  'chengdu', 'karachi', 'ulaanbaatar', 'hanoi', 'wuhan',
  'cairo', 'tehran', 'jakarta', 'bangkok', 'ho-chi-minh-city',
  'mexico-city', 'istanbul', 'seoul', 'tokyo', 'london',
  'new-york-ny', 'paris', 'los-angeles-ca', 'sydney',
  'singapore', 'dubai', 'zurich', 'stockholm', 'kuala-lumpur',
  'sao-paulo', 'bogota', 'johannesburg',
];

const rankingCities = rankingCityIds
  .map(slug => cities.find(c => c.slug === slug))
  .filter(Boolean);
---

<Base
  title="World Air Quality Rankings — Most & Least Polluted Cities | IsTheAirSafe.com"
  description="Live air quality rankings for 30 major world cities. See which cities have the worst and best air quality right now, ranked by real-time AQI."
  canonical="/rankings"
>
  <div class="container" style="padding-top:3rem;padding-bottom:5rem;">
    <div style="max-width:760px;">
      <p style="font-family:var(--font-mono);font-size:0.8rem;color:var(--accent);margin-bottom:0.75rem;text-transform:uppercase;letter-spacing:0.06em;">Live Rankings</p>
      <h1 style="font-size:clamp(2rem,5vw,3rem);letter-spacing:-0.03em;margin-bottom:1rem;">World Air Quality Rankings</h1>
      <p style="font-size:1.05rem;color:var(--text-muted);margin-bottom:0.5rem;">Real-time AQI for 30 major cities, ranked worst to best. Data loads live on each visit.</p>
    </div>

    <!-- Loading state -->
    <div id="loading-msg" style="margin-top:2rem;font-family:var(--font-mono);font-size:0.85rem;color:var(--text-muted);display:flex;align-items:center;gap:0.5rem;">
      <span style="display:inline-block;width:10px;height:10px;border-radius:50%;border:2px solid var(--accent);border-top-color:transparent;animation:spin 0.8s linear infinite;"></span>
      Fetching live AQI data…
    </div>

    <!-- Desktop table (hidden on mobile) -->
    <div id="rankings-table" class="card desktop-only" style="margin-top:1.5rem;overflow:hidden;display:none;">
      <table style="width:100%;border-collapse:collapse;font-size:0.9rem;">
        <thead>
          <tr style="border-bottom:2px solid var(--border);background:var(--bg);">
            <th style="text-align:left;padding:0.875rem 1.25rem;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted);font-weight:600;">#</th>
            <th style="text-align:left;padding:0.875rem 1rem;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted);font-weight:600;">City</th>
            <th style="text-align:left;padding:0.875rem 1rem;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted);font-weight:600;">Country</th>
            <th style="text-align:center;padding:0.875rem 1rem;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted);font-weight:600;">AQI</th>
            <th style="text-align:left;padding:0.875rem 1rem;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted);font-weight:600;">Status</th>
            <th style="padding:0.875rem 1.25rem;"></th>
          </tr>
        </thead>
        <tbody id="rankings-tbody"></tbody>
      </table>
    </div>

    <!-- Mobile cards (hidden on desktop) -->
    <div id="rankings-cards" class="mobile-only" style="margin-top:1.5rem;display:none;flex-direction:column;gap:0.6rem;"></div>

    <!-- AQI Legend -->
    <div style="margin-top:2rem;">
      <p style="font-size:0.8rem;color:var(--text-muted);font-family:var(--font-mono);margin-bottom:0.75rem;">AQI Scale:</p>
      <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
        {[
          { range:'0–50',    label:'Good',         color:'#4ade80', bg:'#f0fdf4', text:'#166534' },
          { range:'51–100',  label:'Moderate',     color:'#facc15', bg:'#fefce8', text:'#854d0e' },
          { range:'101–150', label:'Sensitive',    color:'#fb923c', bg:'#fff7ed', text:'#9a3412' },
          { range:'151–200', label:'Unhealthy',    color:'#f87171', bg:'#fef2f2', text:'#991b1b' },
          { range:'201–300', label:'Very Unhealthy',color:'#c084fc', bg:'#faf5ff', text:'#6b21a8' },
          { range:'301+',    label:'Hazardous',    color:'#f43f5e', bg:'#fff1f2', text:'#881337' },
        ].map(b => (
          <span style={`display:inline-flex;align-items:center;gap:0.35rem;padding:0.25rem 0.7rem;background:${b.bg};color:${b.text};border:1px solid ${b.color}40;border-radius:100px;font-size:0.75rem;font-weight:600;`}>
            <span style={`width:8px;height:8px;background:${b.color};border-radius:50%;display:inline-block;flex-shrink:0;`}></span>
            {b.range} {b.label}
          </span>
        ))}
      </div>
    </div>

    <p style="margin-top:1.5rem;font-size:0.8rem;color:var(--text-subtle);font-family:var(--font-mono);">
      Data from the World Air Quality Index (WAQI) project. Rankings refresh on each page visit.
      <a href="/">← Search all 400+ cities</a>
    </p>
  </div>

  <style>
    @keyframes spin { to { transform:rotate(360deg); } }
    @keyframes fadeIn { from{opacity:0;transform:translateY(6px)} to{opacity:1;transform:translateY(0)} }
    .ranking-row:hover { background:rgba(45,106,79,0.04) !important; }
    .desktop-only { display:block; }
    .mobile-only  { display:none !important; }
    @media (max-width:640px) {
      .desktop-only { display:none !important; }
      .mobile-only  { display:flex !important; }
    }
  </style>

  <script define:vars={{ rankingCities }}>
    const AQI_LEVELS = [
      { max:50,  label:'Good',          color:'#4ade80', bg:'#f0fdf4', text:'#166534' },
      { max:100, label:'Moderate',      color:'#facc15', bg:'#fefce8', text:'#854d0e' },
      { max:150, label:'Sensitive',     color:'#fb923c', bg:'#fff7ed', text:'#9a3412' },
      { max:200, label:'Unhealthy',     color:'#f87171', bg:'#fef2f2', text:'#991b1b' },
      { max:300, label:'Very Unhealthy',color:'#c084fc', bg:'#faf5ff', text:'#6b21a8' },
      { max:999, label:'Hazardous',     color:'#f43f5e', bg:'#fff1f2', text:'#881337' },
    ];
    function getLevel(aqi) { return AQI_LEVELS.find(l => aqi <= l.max) || AQI_LEVELS.at(-1); }

    async function loadRankings() {
      const slugs = rankingCities.map(c => c.slug).join(',');
      let data = {};
      try {
        const res = await fetch(`/api/aqi?slugs=${slugs}`);
        data = await res.json();
      } catch(e) { console.error('Failed to load rankings', e); }

      // Sort cities: AQI desc (worst first), nulls last
      const sorted = [...rankingCities]
        .map(city => ({ city, aqi: typeof data[city.slug] === 'number' ? data[city.slug] : null }))
        .sort((a, b) => {
          if (a.aqi === null && b.aqi === null) return 0;
          if (a.aqi === null) return 1;
          if (b.aqi === null) return -1;
          return b.aqi - a.aqi;
        });

      // Hide loading
      document.getElementById('loading-msg').style.display = 'none';

      // --- Desktop table ---
      const tbody = document.getElementById('rankings-tbody');
      sorted.forEach((item, i) => {
        const l = item.aqi !== null ? getLevel(item.aqi) : null;
        const tr = document.createElement('tr');
        tr.className = 'ranking-row';
        tr.style.cssText = `border-bottom:1px solid var(--border-light);background:${i%2===0?'white':'var(--bg)'};animation:fadeIn 0.3s ease ${i*30}ms both;`;
        tr.innerHTML = `
          <td style="padding:1rem 1.25rem;font-family:var(--font-mono);font-size:0.8rem;color:var(--text-muted);width:3rem;">${item.aqi !== null ? i+1 : '—'}</td>
          <td style="padding:1rem;">
            <a href="${item.city.url}" style="font-weight:600;color:var(--text);text-decoration:none;font-size:0.95rem;">${item.city.name}</a>
            ${item.city.state ? `<span style="display:block;font-size:0.75rem;color:var(--text-muted);">${item.city.state}</span>` : ''}
          </td>
          <td style="padding:1rem;color:var(--text-muted);font-size:0.875rem;white-space:nowrap;">${item.city.country}</td>
          <td style="padding:1rem;text-align:center;">
            ${item.aqi !== null ? `<span style="font-family:var(--font-mono);font-size:1.1rem;font-weight:500;color:${l.color};">${item.aqi}</span>` : '<span style="color:var(--text-subtle);font-family:var(--font-mono);">—</span>'}
          </td>
          <td style="padding:1rem;">
            ${l ? `<span style="display:inline-block;padding:0.2rem 0.6rem;border-radius:100px;font-size:0.75rem;font-weight:600;background:${l.bg};color:${l.text};border:1px solid ${l.color}40;white-space:nowrap;">${l.label}</span>` : '<span style="font-size:0.75rem;color:var(--text-subtle);">No data</span>'}
          </td>
          <td style="padding:1rem 1.25rem;text-align:right;"><a href="${item.city.url}" style="font-size:0.8rem;font-family:var(--font-mono);color:var(--accent);white-space:nowrap;">Details →</a></td>
        `;
        tbody.appendChild(tr);
      });
      document.getElementById('rankings-table').style.display = 'block';

      // --- Mobile cards ---
      const cardsEl = document.getElementById('rankings-cards');
      sorted.forEach((item, i) => {
        const l = item.aqi !== null ? getLevel(item.aqi) : null;
        const card = document.createElement('a');
        card.href = item.city.url;
        card.style.cssText = `display:flex;align-items:center;justify-content:space-between;background:white;border:1px solid ${l ? l.color+'40' : 'var(--border)'};border-radius:12px;padding:14px 16px;text-decoration:none;gap:12px;animation:fadeIn 0.3s ease ${i*20}ms both;`;
        card.innerHTML = `
          <div style="display:flex;align-items:center;gap:12px;min-width:0;">
            <span style="font-family:var(--font-mono);font-size:0.75rem;color:var(--text-subtle);width:20px;flex-shrink:0;">${item.aqi !== null ? i+1 : '—'}</span>
            <div style="min-width:0;">
              <div style="font-weight:600;font-size:0.95rem;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${item.city.name}</div>
              <div style="font-size:0.75rem;color:var(--text-muted);">${item.city.country}${item.city.state ? ', '+item.city.state : ''}</div>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">
            ${l ? `<span style="display:inline-block;padding:0.2rem 0.5rem;border-radius:100px;font-size:0.7rem;font-weight:600;background:${l.bg};color:${l.text};border:1px solid ${l.color}40;white-space:nowrap;">${l.label}</span>` : ''}
            ${item.aqi !== null ? `<span style="font-family:var(--font-mono);font-size:1.2rem;font-weight:500;color:${l.color};min-width:36px;text-align:right;">${item.aqi}</span>` : '<span style="font-family:var(--font-mono);color:var(--text-subtle);">—</span>'}
          </div>
        `;
        cardsEl.appendChild(card);
      });
    }

    loadRankings();
  </script>
</Base>
